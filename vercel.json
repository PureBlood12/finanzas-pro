{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "installCommand": "cd server && npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/client/dist/$1" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 10
    }
  }
}
