{
  "name": "finanzas-pro",
  "version": "1.0.0",
  "description": "Personal Finance Management App",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "cd server && npm start",
    "client": "cd client && npm run dev",
